{
    "meta"= "Rules 2 is for Grimdark Future OPR. https://army-forge.onepagerules.com/api/rules/common/2",
    "rules"= [
        {
            "id": "3FeiOe3krHMa",
            "name": "Aircraft",
            "description": "May only use Advance actions, moving in a straight line, and adding 30” to its total move (even if Shaken). Aircraft ignore all units and terrain when moving and stopping, can’t seize or contest objectives, can’t be charged, and units targeting them get -12” range.",
            "coreType": 1
        },
        {
            "id": "6mJw5IdqSqNC",
            "name": "Ambush",
            "description": "May be set aside before deployment. At the start of any round after the first, may be deployed anywhere over 9” away from enemy units. Players alternate in placing Ambush units, starting with the player that activates next. Units that deploy via Ambush can’t seize or contest objectives on the round they deploy.",
            "coreType": 1
        },
        {
            "id": "17crjK7P6_w6",
            "name": "AP",
            "description": "Targets get -X to Defense rolls when blocking hits.",
            "coreType": 1
        },
        {
            "id": "GRuFoZiyjY5f",
            "name": "Artillery",
            "description": "May only use Hold actions. When this model shoots at enemies over 9\" away, it gets +1 to hit rolls. When enemy units shoot at this model from over 9\" away, they get -2 to hit rolls.",
            "coreType": 1
        },
        {
            "id": "Naqc5mga9Uha",
            "name": "Bane",
            "description": "Ignores Regeneration, and when attacking the target must re-roll unmodified Defense results of 6.",
            "coreType": 1
        },
        {
            "id": "ywXKQKPOLjTF",
            "name": "Banner",
            "description": "This model and its unit get +1 to morale test rolls.",
            "coreType": 1
        },
        {
            "id": "w_vX0mi58KKt",
            "name": "Blast",
            "description": "Ignores cover, and after resolving other special rules, each hit is multiplied by X, where X is up to as many hits as models in the target unit.",
            "coreType": 1
        },
        {
            "id": "47CAqf7ySlfc",
            "name": "Caster",
            "description": "Gets X spell tokens at the start of each round, but can’t hold more than 6 tokens at once. At any point before attacking, spend as many tokens as the spell’s value to try casting one or more spells (only one try per spell). Roll one die, on 4+ resolve the effect on a target in line of sight. Models within 18” in line of sight of the caster’s unit may spend any number of spell tokens at the same time before rolling, to give the caster +1/-1 to the roll per token.",
            "coreType": 1
        },
        {
            "id": "c45Fw0D2oGOk",
            "name": "Counter",
            "description": "Strikes first with this weapon when charged, and the charging unit gets -1 total Impact rolls per model with Counter.",
            "coreType": 1
        },
        {
            "id": "_mrPya5SXSqW",
            "name": "Deadly",
            "description": "Assign each wound to one model, and multiply it by X. Hits from Deadly must be resolved first, and these wounds don’t carry over to other models if the original target is killed.",
            "coreType": 1
        },
        {
            "id": "wHfLIdlnEQ1a",
            "name": "Entrenched",
            "description": "As long as a unit where all models have this rule hasn't moved during the round, enemy units shooting at it from over 9\" away get -2 to hit rolls.",
            "coreType": 1
        },
        {
            "id": "KdgwlPb8LuD2",
            "name": "Fast",
            "description": "Moves +2\" when using Advance, and +4” when using Rush/Charge.",
            "coreType": 1
        },
        {
            "id": "dIQ3SGl2J2Ew",
            "name": "Fear",
            "description": "This model counts as having dealt +X wounds when checking who won melee.",
            "coreType": 1
        },
        {
            "id": "2atvlmICQSCV",
            "name": "Fearless",
            "description": "When a unit where all models have this rule fails a morale test, roll one die. On a 4+ it counts as passed instead.",
            "coreType": 1
        },
        {
            "id": "-QJdqJEKjIpE",
            "name": "Flying",
            "description": "May move through units and terrain, and ignores terrain effects whilst moving.",
            "coreType": 1
        },
        {
            "id": "JoOCVPx1xT1G",
            "name": "Furious",
            "description": "When charging, unmodified results of 6 to hit in melee deal 1 extra hit (only the original hit counts as a 6 for special rules).",
            "coreType": 1
        },
        {
            "id": "T08VkBuVmNZ_",
            "name": "Hero",
            "description": "Heroes with up to Tough(6) may deploy as part of one multi-model unit without another Hero. The hero may take morale tests on behalf of the unit, but must use the unit’s Defense until all other models have been killed.",
            "coreType": 1
        },
        {
            "id": "HWtnPV9LQF1D",
            "name": "Immobile",
            "description": "May only use Hold actions.",
            "coreType": 1
        },
        {
            "id": "62-mYKVM9MLd",
            "name": "Impact",
            "description": "Roll X dice when attacking after charging, unless fatigued. For each 2+ the target takes one hit.",
            "coreType": 1
        },
        {
            "id": "8Ck9GAwUK824",
            "name": "Indirect",
            "description": "Gets -1 to hit rolls when shooting after moving. May target enemies that are not in line of sight as if in line of sight, and ignores cover from sight obstructions.",
            "coreType": 1
        },
        {
            "id": "9042COVrLCsI",
            "name": "Limited",
            "description": "May only be used once per game.",
            "coreType": 1
        },
        {
            "id": "PXIxtMdcLyqp",
            "name": "Morale",
            "description": "Gets +X to morale test rolls.",
            "coreType": 1
        },
        {
            "id": "qrG_DXJez5Dg",
            "name": "Musician",
            "description": "This model and its unit moves +1\" when using move actions.",
            "coreType": 1
        },
        {
            "id": "8KujvrTG8k9p",
            "name": "Regeneration",
            "description": "When a unit where all models have this rule takes wounds, roll one die for each. On a 5+ it is ignored.",
            "coreType": 1
        },
        {
            "id": "H9E9PIWpGRdw",
            "name": "Relentless",
            "description": "When this model shoots at enemies over 9\" away, unmodified results of 6 to hit deal 1 extra hit (only the original hit counts as a 6 for special rules).",
            "coreType": 1
        },
        {
            "id": "Zx4mWN0SbmK8",
            "name": "Reliable",
            "description": "Attacks at Quality 2+.",
            "coreType": 1
        },
        {
            "id": "cavWDboL4ubs",
            "name": "Rending",
            "description": "Ignores Regeneration, and on unmodified results of 6 to hit, those hits get AP(+4).",
            "coreType": 1
        },
        {
            "id": "FAMbscK5vhSu",
            "name": "Scout",
            "description": "May be set aside before deployment. After all other units are deployed, may be deployed anywhere fully within 12” of their deployment zone. Players alternate in placing Scout units, starting with the player that activates next.",
            "coreType": 1
        },
        {
            "id": "Ldhtmr4H8b6G",
            "name": "Slow",
            "description": "Moves -2\" when using Advance, and -4” when using Rush/Charge.",
            "coreType": 1
        },
        {
            "id": "LGYXUcXfcJac",
            "name": "Sniper REMOVE",
            "description": "Shoots at Quality 2+, and each model with Sniper may pick any model in the target unit as its individual target, which is resolved as if it was a unit of 1. Sniper shooting must be resolved before other weapons.",
            "coreType": 1
        },
        {
            "id": "9jyvRoBODD-O",
            "name": "Stealth",
            "description": "When units where all models have this rule are shot from over 9\" away, enemy units get -1 to hit rolls.",
            "coreType": 1
        },
        {
            "id": "JSKVyurtWIyW",
            "name": "Strider",
            "description": "May ignore the effects of difficult terrain when moving. ",
            "coreType": 1
        },
        {
            "id": "8Hjy54TYtwb7",
            "name": "Takedown",
            "description": "This model may pick any model in the target unit as its individual target, which is resolved as if it was a unit of [1]. Takedown attacks must be resolved before other weapons.",
            "coreType": 1
        },
        {
            "id": "umbiz4tnEyF8",
            "name": "Thrust",
            "description": "When charging, gets +1 to hit rolls and AP(+1) in melee.",
            "coreType": 1
        },
        {
            "id": "a0YtInGiUDd6",
            "name": "Tough",
            "description": "This model must take X wounds before being killed. If a model with tough joins a unit without it, then it is removed last when the unit takes wounds. You must continue to put wounds on the tough model with most wounds in the unit until it is killed, before starting to put them on the next tough model (heroes must be assigned wounds last, even if already wounded).",
            "coreType": 1
        },
        {
            "id": "aogQZcOOQrDI",
            "name": "Transport",
            "description": "May transport up to X models or Heroes with up to Tough(6), and non-Heroes with up to Tough(3) which occupy 3 spaces each. Transports may deploy with units inside, and units may enter/exit by using any move action, but must stay fully within 6\" of it when exiting. Units inside/outside transports may not target other units outside/inside transports, but may target the transport itself. When a transport is destroyed, units inside must take a dangerous terrain test, are Shaken, and must be placed fully within 6” of the transport before it’s removed.",
            "coreType": 1
        },
        {
            "id": "QXyt-zV_bjpg",
            "name": "Unstoppable",
            "description": "Ignores Regeneration, and ignores all negative modifiers to this weapon.",
            "coreType": 1
        }
    ],
